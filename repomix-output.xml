    url: '$baseUrl$url',
    poster: img,
    number: _parseNumber(anime.querySelector('.number > span')?.text),
    name: anime.querySelector('.film-title')?.text,
    jname: anime.querySelector('.film-title')?.attributes['data-jname'],
