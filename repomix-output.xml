    type: anime.querySelector('.sc-detail .scd-item:first-child')?.text.trim(),
    duration: anime.querySelectorAll('.sc-detail .scd-item')[1].text.trim(),
    releaseDate:
        anime.querySelector('.sc-detail .scd-item.m-hide')?.text.trim(),
