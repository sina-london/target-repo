                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    if (isLinux) ...[
                      Text(
                        "Run this command:",
                        style: theme.textTheme.labelLarge,
                      ),
                      const SizedBox(height: 8),
                      Container(
