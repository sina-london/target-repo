}

BaseAnimeModel _parseSpotlightAnime(dom.Element anime, String baseUrl) {
  return BaseAnimeModel(
    id: '${anime.querySelector('a')?.attributes['href']?.split('/').last}',
    url: '$baseUrl${anime.querySelector('a')?.attributes['href'] ?? ''}',
