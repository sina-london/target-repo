                  onPressed: () =>
                      _showDisconnectDialog(context, ref, name, platform),
                  icon: const Icon(Iconsax.logout),
                  style: IconButton.styleFrom(
                    backgroundColor: colorScheme.errorContainer,
                    foregroundColor: colorScheme.onErrorContainer,
                  ),
                )
              else
